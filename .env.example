# Supabase project URL — found in Project Settings > API
SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase anon/public key — found in Project Settings > API
SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# Supabase project ref (the subdomain of your project URL)
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Edge function secrets (set via `supabase secrets set`, NOT in .env):
# OPENAI_API_KEY — used by the assess-candidate edge function
